<?xml version="1.0"?>
<!DOCTYPE module PUBLIC
        "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
        "https://checkstyle.org/dtds/configuration_1_3.dtd">

<!--
    Javadoc documentation enforcement for CI pipeline.

    Requires Javadoc on public annotation types and on public methods
    exceeding 100 lines. Activated via the "javadoc-check" Maven profile:

        mvn checkstyle:check -Pjavadoc-check

    This configuration is NOT part of the default build to avoid slowing
    down local development. It runs as a separate step in the GitHub
    Actions pipeline, out of the critical path.
-->
<module name="Checker">
    <property name="charset" value="UTF-8"/>
    <property name="severity" value="error"/>

    <!-- Only check main source files, not test sources -->
    <property name="fileExtensions" value="java"/>

    <!-- Exclude auto-generated source files -->
    <module name="BeforeExecutionExclusionFileFilter">
        <property name="fileNamePattern"
                  value="[/\\]generated[/\\]"/>
    </module>

    <module name="TreeWalker">
        <!-- Require Javadoc on public interfaces and annotations -->
        <module name="MissingJavadocType">
            <property name="scope" value="public"/>
            <property name="tokens" value="ANNOTATION_DEF"/>
        </module>

        <!-- Require Javadoc on public methods with 100+ lines.
             Short methods are often self-documenting; longer methods
             benefit from a Javadoc summary of purpose and parameters. -->
        <module name="MissingJavadocMethod">
            <property name="scope" value="public"/>
            <property name="allowMissingPropertyJavadoc" value="true"/>
            <property name="minLineCount" value="100"/>
            <property name="tokens" value="METHOD_DEF"/>
        </module>
    </module>
</module>
