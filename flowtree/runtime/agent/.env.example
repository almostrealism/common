# ─── FlowTree Agent Configuration ────────────────────────────────────
#
# Copy this file to .env and fill in the values.
#
# Generate CLAUDE_CODE_OAUTH_TOKEN by running:
#   claude setup-token
# on any machine where you can authenticate in a browser.
#
# ─────────────────────────────────────────────────────────────────────

# Required: Claude Code authentication
CLAUDE_CODE_OAUTH_TOKEN=

# Required: controller address
FLOWTREE_ROOT_HOST=
FLOWTREE_ROOT_PORT=7766

# Agent pool sizing
AGENT_COUNT=2
AGENT_CPUS=4
AGENT_MEMORY=4g
AGENT_JVM_OPTS=-Xmx2048m

# Git identity for commits
GIT_USER_NAME="Flowtree Coding Agent"
GIT_USER_EMAIL="michael@almostrealism.com"

# SSH keys for private repo access
SSH_KEY_DIR=${HOME}/sandbox/ssh

# Model weights and audio samples (read-only)
MODELS_DIR=/Users/Shared/models
SAMPLES_DIR=${HOME}/Music/Samples

# Optional: node labels (key:value pairs, comma-separated)
# FLOWTREE_NODE_LABELS=team:backend,env:staging

# Optional: OpencodeRunner endpoint. Leave unset to fall back to the
# compiled-in default (http://localhost:11434/v1 inside the container,
# typically not useful). For the Qwen3-Coder llama.cpp setup on
# mac-studio over Tailscale:
#   OPENCODE_PROVIDER_URL=http://mac-studio:8084/v1
#   OPENCODE_DEFAULT_MODEL=qwen3-coder-30b
#   OPENCODE_API_KEY=
# rebuild.sh --with-llm writes the ollama variant of these keys
# automatically when invoked.
