{
  "display_information": {
    "name": "flowtree.io",
    "description": "Slack controls for flowtree.io nodes",
    "background_color": "#2c2d30"
  },
  "features": {
    "app_home": {
      "messages_tab_enabled": true,
      "messages_tab_read_only_enabled": false
    },
    "bot_user": {
      "display_name": "flowtree.io",
      "always_online": true
    },
    "slash_commands": [
      {
        "command": "/flowtree",
        "description": "Manage the workstream for this channel",
        "usage_hint": "setup <dir> <branch> | info | status | task <prompt> | cancel [job-id] | config [key] [value] | jobs"
      }
    ]
  },
  "oauth_config": {
    "scopes": {
      "bot": [
        "app_mentions:read",
        "chat:write",
        "commands",
        "im:history",
        "im:read",
        "im:write",
        "channels:manage",
        "channels:read",
        "channels:write.invites",
        "groups:read",
        "groups:write",
        "groups:write.invites"
      ]
    }
  },
  "settings": {
    "event_subscriptions": {
      "bot_events": [
        "app_mention",
        "message.im"
      ]
    },
    "org_deploy_enabled": false,
    "socket_mode_enabled": true,
    "token_rotation_enabled": false
  }
}
