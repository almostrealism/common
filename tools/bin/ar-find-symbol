#!/usr/bin/env python3
"""
ar-find-symbol: Find all usages of a Java symbol across the codebase.

Usage: ar-find-symbol <symbol> [root_dir] [options]

Options:
  --files         Print only file paths (no context lines)
  --context N     Print N lines of context around each match (default: 1)
  --java-only     Search only .java files (default)
  --all           Search all text files

Searches for the symbol as a whole word. Useful for finding all usages of
a class name, method name, field name, or constant.

Examples:
  ar-find-symbol ClaudeCodeJob
  ar-find-symbol isViolated flowtree/ --context 2
  ar-find-symbol EnforcementRule --files
  ar-find-symbol DEFAULT_MAX_RULE_RETRIES
"""

import re
import sys
from pathlib import Path


def search(symbol, root, context_lines=1, files_only=False, all_files=False):
    """Search for symbol usages and print results."""
    pattern = re.compile(r'\b' + re.escape(symbol) + r'\b')
    extensions = ('*',) if all_files else ('*.java', '*.py', '*.xml', '*.yaml', '*.yml', '*.md')

    total_matches = 0
    files_with_matches = 0

    for ext in extensions:
        for path in sorted(root.rglob(ext)):
            if path.is_dir():
                continue
            if 'target' in path.parts or 'generated' in path.parts or '.git' in path.parts:
                continue
            try:
                lines = path.read_text(encoding='utf-8', errors='replace').splitlines()
            except OSError:
                continue

            matches = [(i, line) for i, line in enumerate(lines) if pattern.search(line)]
            if not matches:
                continue

            try:
                rel = path.relative_to(root)
            except ValueError:
                rel = path

            files_with_matches += 1
            total_matches += len(matches)

            if files_only:
                print(str(rel))
                continue

            print(f'\n{"─" * 72}')
            print(f'{rel}  ({len(matches)} match(es))')
            print('─' * 72)

            shown = set()
            for line_idx, line in matches:
                start = max(0, line_idx - context_lines)
                end = min(len(lines) - 1, line_idx + context_lines)
                for j in range(start, end + 1):
                    if j in shown:
                        continue
                    shown.add(j)
                    marker = '>>>' if j == line_idx else '   '
                    print(f'{marker} {j + 1:5d}  {lines[j]}')
                if context_lines > 0 and line_idx + context_lines < len(lines) - 1:
                    print()

    if not files_only:
        print(f'\nTotal: {total_matches} occurrence(s) in {files_with_matches} file(s).')
    return total_matches


def main():
    if len(sys.argv) < 2 or sys.argv[1] in ('-h', '--help'):
        print(__doc__)
        sys.exit(0 if sys.argv[1:] else 1)

    symbol = sys.argv[1]
    args = sys.argv[2:]

    root_str = '.'
    context_lines = 1
    files_only = False
    all_files = False

    i = 0
    while i < len(args):
        arg = args[i]
        if arg == '--files':
            files_only = True
        elif arg == '--context' and i + 1 < len(args):
            i += 1
            context_lines = int(args[i])
        elif arg == '--all':
            all_files = True
        elif arg == '--java-only':
            all_files = False
        elif not arg.startswith('--'):
            root_str = arg
        i += 1

    root = Path(root_str)
    found = search(symbol, root, context_lines, files_only, all_files)
    if found == 0:
        print(f"Symbol '{symbol}' not found.")


if __name__ == '__main__':
    main()
