#!/usr/bin/env python3
"""
ar-find-callers: Find all call sites of a Java method.

Usage: ar-find-callers <method_name> [root_dir] [options]

Options:
  --context N     Lines of context around each call site (default: 2)
  --files         Print only file paths

Searches for patterns like `method_name(` and `.method_name(` to find
invocation sites. Also finds super.method_name() and this.method_name().
Ignores method declarations (lines that look like definitions).

To find declarations instead, use ar-find-method.
To find all usages (including declarations), use ar-find-symbol.

Examples:
  ar-find-callers handleSubmit
  ar-find-callers isViolated flowtree/ --context 3
  ar-find-callers forward --files
  ar-find-callers evaluate flowtree/
"""

import re
import sys
from pathlib import Path


# Matches an invocation: optional qualifier + dot + method + open paren
# Deliberately avoids matching declaration lines (which have return types before the name)
INVOCATION = re.compile(r'(?:[\w\)\]>]\.)\s*(\w+)\s*\(|(?<!\w)(\w+)\s*\((?!\s*\{)')
# Simpler: just find .methodName( or methodName( where it looks like a call
CALL_PATTERN_TEMPLATE = r'(?:[\w\)\]>\"\']\s*\.\s*|(?<![a-zA-Z0-9_])(?:return\s+|=\s*|,\s*|\(\s*|&&\s*|\|\|\s*|!\s*|throw\s+new\s+\w+\())\s*){method}\s*\('

DECL_PATTERN = re.compile(
    r'^\s*(?:(?:public|private|protected|static|final|synchronized|default|abstract'
    r'|native|override|transient|volatile)\s+)+'
    r'(?:<[^>]+>\s+)?'
    r'[\w\[\]<>.,?\s]+\s+'
    r'{method}\s*\(',
)


def is_declaration(line, method_name):
    """Return True if the line looks like a method declaration, not a call."""
    pattern = DECL_PATTERN.pattern.format(method=re.escape(method_name))
    return bool(re.match(pattern, line))


def search(method_name, root, context_lines=2, files_only=False):
    """Find all call sites of method_name under root."""
    # Match any occurrence of the method name followed by (
    # that isn't a declaration
    call_re = re.compile(r'\b' + re.escape(method_name) + r'\s*\(')

    total = 0
    file_count = 0

    for path in sorted(root.rglob('*.java')):
        if 'target' in path.parts or 'generated' in path.parts:
            continue
        try:
            lines = path.read_text(encoding='utf-8', errors='replace').splitlines()
        except OSError:
            continue

        call_sites = []
        for i, line in enumerate(lines):
            if call_re.search(line) and not is_declaration(line, method_name):
                call_sites.append(i)

        if not call_sites:
            continue

        try:
            rel = path.relative_to(root)
        except ValueError:
            rel = path

        file_count += 1
        total += len(call_sites)

        if files_only:
            print(str(rel))
            continue

        print(f'\n{"─" * 72}')
        print(f'{rel}  ({len(call_sites)} call site(s))')
        print('─' * 72)

        shown = set()
        for site in call_sites:
            start = max(0, site - context_lines)
            end = min(len(lines) - 1, site + context_lines)
            for j in range(start, end + 1):
                if j in shown:
                    continue
                shown.add(j)
                marker = '>>>' if j == site else '   '
                print(f'{marker} {j + 1:5d}  {lines[j]}')
            print()

    if not files_only:
        print(f'\nTotal: {total} call site(s) in {file_count} file(s).')
    return total


def main():
    if len(sys.argv) < 2 or sys.argv[1] in ('-h', '--help'):
        print(__doc__)
        sys.exit(0 if sys.argv[1:] else 1)

    method_name = sys.argv[1]
    args = sys.argv[2:]

    root_str = '.'
    context_lines = 2
    files_only = False

    i = 0
    while i < len(args):
        arg = args[i]
        if arg == '--files':
            files_only = True
        elif arg == '--context' and i + 1 < len(args):
            i += 1
            context_lines = int(args[i])
        elif not arg.startswith('--'):
            root_str = arg
        i += 1

    root = Path(root_str)
    found = search(method_name, root, context_lines, files_only)
    if found == 0:
        print(f"No call sites for '{method_name}' found.")


if __name__ == '__main__':
    main()
