# ─── AR CI macOS Runner Configuration ──────────────────────────────────
# Copy this file to .env and fill in the values before starting.
#
#   cp .env.example .env
#   $EDITOR .env

# GitHub personal access token with 'repo' and 'admin:org' scopes
# (or fine-grained token with Administration read/write + Actions read)
GITHUB_PAT=ghp_your_token_here

# Registration scope: "repo" (default) registers against a single repository;
# "org" registers at the organization level so every repository in the org can
# share this runner (subject to the runner group's repository-access policy in
# Org Settings -> Actions -> Runner groups). Use "org" to share Macs between
# common and ringsdesktop.
# RUNNER_SCOPE=org

# GitHub owner (org or user). Always required.
GITHUB_OWNER=almostrealism

# Repository name. Required only when RUNNER_SCOPE=repo; ignored for org scope.
GITHUB_REPO=common

# Runner name (default: $(hostname)-macos)
# RUNNER_NAME=my-mac-runner

# Runner group (default: Default)
# RUNNER_GROUP=Default

# Working directory for job execution (default: ~/actions-runner/_work)
# RUNNER_WORKDIR=/path/to/workdir

# Maximum CPUs the runner job is allowed to use (default: no limit).
# Requires cpulimit (brew install cpulimit). Ignored if cpulimit is
# not installed. Set based on the machine's capability — e.g. 4 on a
# shared Mac Mini, 8 on a dedicated Mac Studio.
# RUNNER_CPU_LIMIT=4
