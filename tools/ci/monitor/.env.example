# ─── AR Host Resource Monitor Configuration ─────────────────────────────
# Copy this file to .env and adjust values as needed.
#
#   cp .env.example .env
#   $EDITOR .env

# Seconds between samples (default: 10)
# MONITOR_INTERVAL=10

# Directory for JSONL log files (default: ./logs)
# MONITOR_LOG_DIR=./logs

# Minimum %CPU for a process to be recorded (default: 5.0)
# MONITOR_CPU_THRESHOLD=5.0

# Minimum %MEM for a process to be recorded (default: 2.0)
# MONITOR_MEM_THRESHOLD=2.0

# Days to retain log files before cleanup (default: 14)
# MONITOR_RETENTION_DAYS=14

# Label for this machine (default: $(hostname -s))
# HOSTNAME_LABEL=mac-studio
