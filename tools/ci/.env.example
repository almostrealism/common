# ─── AR CI Runner Fleet Configuration ─────────────────────────────────
# Copy this file to .env and fill in the values before starting.
#
#   cp .env.example .env
#   $EDITOR .env

# GitHub personal access token with 'repo' and 'admin:org' scopes
# (or fine-grained token with Administration read/write + Actions read)
GITHUB_PAT=ghp_your_token_here

# GitHub owner (org or user) and repository name
GITHUB_OWNER=almostrealism
GITHUB_REPO=common

# Number of runner containers to launch (default: 10)
# The workflow uses 7 matrix groups + ml + audio + music = 10 concurrent test jobs
RUNNER_SCALE=10

# Memory limit per container (default: 16g)
# Each runner needs enough for JDK + Maven + AR tests
RUNNER_MEMORY_LIMIT=16g

# CPU limit per container (default: 4 cores)
RUNNER_CPU_LIMIT=4

# AR hardware memory scale (default: 7 = 8GB, use 8 = 16GB for large tests)
AR_HARDWARE_MEMORY_SCALE=7
