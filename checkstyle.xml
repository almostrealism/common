<?xml version="1.0"?>
<!DOCTYPE module PUBLIC
        "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
        "https://checkstyle.org/dtds/configuration_1_3.dtd">

<!--
    Project-wide code quality rules applied to every module in the default build.

    Rules applied:
      - FileLength           : Java source files are capped at 1600 lines.  Files
                               larger than this are a sign that a class is doing
                               too much and should be split into focused collaborators.
                               A small set of legacy files exceeds this limit and is
                               individually exempted via SuppressionSingleFilter (see
                               below).  Those files are tracked by
                               scripts/check-exempt-file-lengths.sh, which enforces
                               that they do not grow beyond their current sizes.
      - JavadocPackage       : every package needs a package-info.java with Javadoc
      - MissingJavadocType   : every type declaration needs a Javadoc comment
                               (test sources exempt)
      - MissingJavadocMethod : every method and constructor needs a Javadoc comment
                               (test sources exempt)
      - JavadocVariable      : every field needs a Javadoc comment
                               (test sources exempt)
      - RegexpSinglelineJava : prohibits use of 'var' and '@SuppressWarnings'
      - RegexpSinglelineJava : prohibits System.out/err and e.printStackTrace().
                               Use Console.root() or implement ConsoleFeatures instead.
                               191 legacy files are suppressed via checkstyle-suppressions.xml
                               and must be migrated over time.  New files may not be added
                               to the suppression list.
      - RegexpSinglelineJava : prohibits bracket-prefixed labels in log/warn calls,
                               e.g. log("[Tag] message").  Write messages directly.
                               Enforced at severity=error.  No suppressions permitted.
-->
<module name="Checker">
    <property name="charset" value="UTF-8"/>
    <property name="severity" value="error"/>
    <property name="fileExtensions" value="java"/>

    <!-- Exclude auto-generated source files -->
    <module name="BeforeExecutionExclusionFileFilter">
        <property name="fileNamePattern" value="[/\\]generated[/\\]"/>
    </module>

    <!-- Cap Java source files at 1600 lines.  Files larger than this are a
         sign that a class is doing too much and should be split into focused
         collaborators.  The limit was lowered from 1800 to 1600 to reduce
         the amount of context agents must read to understand a class.
         A small set of legacy files exceeds this limit and is individually
         exempted via SuppressionSingleFilter (see below).  All are tracked
         by scripts/check-exempt-file-lengths.sh, which enforces that they
         do not grow beyond their sizes at the time of exemption. -->
    <module name="FileLength">
        <property name="max" value="1600"/>
    </module>

    <!-- Exempt legacy files that currently exceed 1600 lines.  These files are
         tracked by scripts/check-exempt-file-lengths.sh, which prevents them
         from growing beyond their sizes at the time of exemption.
         To remove an exemption: split the file below 1600 lines, then remove
         its SuppressionSingleFilter entry and its entry in check-exempt-file-lengths.sh. -->

    <!-- Pre-existing exemptions (exceeded 1800 lines): -->
    <module name="SuppressionSingleFilter">
        <property name="checks" value="FileLength"/>
        <property name="files" value="CollectionFeatures\.java"/>
    </module>
    <module name="SuppressionSingleFilter">
        <property name="checks" value="FileLength"/>
        <property name="files" value="Expression\.java"/>
    </module>
    <module name="SuppressionSingleFilter">
        <property name="checks" value="FileLength"/>
        <property name="files" value="AttentionFeatures\.java"/>
    </module>
    <!-- Console.java is the logging system itself — it must write to System.out/err
         directly to deliver output.  The DirectSystemOut rule is suppressed for it. -->
    <module name="SuppressionSingleFilter">
        <property name="id" value="DirectSystemOut"/>
        <property name="files" value="Console\.java"/>
    </module>

    <!-- Test sources are exempt from all checkstyle rules so that existing test
         files don't require package-info.java or per-method javadoc, and
         don't trigger log prefix or other style rules. FileLength and all
         other Checker-level rules still apply to both main and test sources.
         This exemption is intentionally broad: enabling includeTestSourceDirectory
         was for FileLength enforcement only; other rules would require significant
         migration work across the test corpus. -->
    <module name="SuppressionSingleFilter">
        <property name="checks" value="JavadocPackage"/>
        <property name="files" value=".*[/\\]test[/\\]"/>
    </module>
    <module name="SuppressionSingleFilter">
        <property name="checks" value="MissingJavadocType"/>
        <property name="files" value=".*[/\\]test[/\\]"/>
    </module>
    <module name="SuppressionSingleFilter">
        <property name="checks" value="MissingJavadocMethod"/>
        <property name="files" value=".*[/\\]test[/\\]"/>
    </module>
    <module name="SuppressionSingleFilter">
        <property name="checks" value="JavadocVariable"/>
        <property name="files" value=".*[/\\]test[/\\]"/>
    </module>

    <!-- Exempt test sources from log prefix and DirectSystemOut rules.
         These use id rather than checks because the checks property pattern
         matching doesn't work correctly for RegexpSinglelineJava-based checks. -->
    <module name="SuppressionSingleFilter">
        <property name="id" value="BracketLabelInLog"/>
        <property name="files" value=".*[/\\]test[/\\]"/>
    </module>
    <module name="SuppressionSingleFilter">
        <property name="id" value="CapsLabelInLog"/>
        <property name="files" value=".*[/\\]test[/\\]"/>
    </module>
    <module name="SuppressionSingleFilter">
        <property name="id" value="DirectSystemOut"/>
        <property name="files" value=".*[/\\]test[/\\]"/>
    </module>

    <!-- Exempt test sources from FileLength check.
         Test files are often long due to test infrastructure and are validated
         through other means. This allows includeTestSourceDirectory=true for
         FileLength enforcement on MAIN sources without failing on test files. -->
    <module name="SuppressionSingleFilter">
        <property name="checks" value="FileLength"/>
        <property name="files" value=".*[/\\]test[/\\]"/>
    </module>

    <!-- Per-file suppressions for main source log prefix violations only. -->
    <module name="SuppressionSingleFilter">
        <property name="id" value="BracketLabelInLog"/>
        <property name="files" value="GruDecoderPdslInferenceTest\.java"/>
    </module>
    <module name="SuppressionSingleFilter">
        <property name="id" value="BracketLabelInLog"/>
        <property name="files" value="GQAExpandTest\.java"/>
    </module>
    <module name="SuppressionSingleFilter">
        <property name="id" value="BracketLabelInLog"/>
        <property name="files" value="MultiTokenGenerationTest\.java"/>
    </module>
    <module name="SuppressionSingleFilter">
        <property name="id" value="BracketLabelInLog"/>
        <property name="files" value="Qwen3DirectGenerationTest\.java"/>
    </module>
    <module name="SuppressionSingleFilter">
        <property name="id" value="BracketLabelInLog"/>
        <property name="files" value="Qwen3EmbeddingTest\.java"/>
    </module>
    <module name="SuppressionSingleFilter">
        <property name="id" value="BracketLabelInLog"/>
        <property name="files" value="Qwen3GenerationDemo\.java"/>
    </module>
    <module name="SuppressionSingleFilter">
        <property name="id" value="BracketLabelInLog"/>
        <property name="files" value="Qwen3SyntheticTest\.java"/>
    </module>
    <module name="SuppressionSingleFilter">
        <property name="id" value="BracketLabelInLog"/>
        <property name="files" value="Qwen3TokenizerTest\.java"/>
    </module>
    <module name="SuppressionSingleFilter">
        <property name="id" value="BracketLabelInLog"/>
        <property name="files" value="SharedEmbeddingsTest\.java"/>
    </module>
    <module name="SuppressionSingleFilter">
        <property name="id" value="CapsLabelInLog"/>
        <property name="files" value="OobleckValidationTest\.java"/>
    </module>
    <module name="SuppressionSingleFilter">
        <property name="id" value="CapsLabelInLog"/>
        <property name="files" value="EncoderCompilationProfileTest\.java"/>
    </module>
    <module name="SuppressionSingleFilter">
        <property name="id" value="CapsLabelInLog"/>
        <property name="files" value="Conv1dCorrectnessTest\.java"/>
    </module>
    <module name="SuppressionSingleFilter">
        <property name="id" value="CapsLabelInLog"/>
        <property name="files" value="Qwen3GenerationDemo\.java"/>
    </module>
    <module name="SuppressionSingleFilter">
        <property name="id" value="CapsLabelInLog"/>
        <property name="files" value="RotationTests\.java"/>
    </module>
    <module name="SuppressionSingleFilter">
        <property name="id" value="CapsLabelInLog"/>
        <property name="files" value="Qwen3DirectGenerationTest\.java"/>
    </module>

    <!-- Require package-info.java with a Javadoc comment for every package.
         Applied at Checker level so it applies to both main and test sources. -->
    <module name="JavadocPackage"/>

    <module name="TreeWalker">
        <module name="MissingJavadocType">
            <property name="scope" value="private"/>
        </module>

        <!-- Every method and constructor must have a Javadoc comment,
             including private helpers.  Property-style getters and setters
             are NOT exempt: they must also document the field they access. -->
        <module name="MissingJavadocMethod">
            <property name="scope" value="private"/>
            <property name="allowMissingPropertyJavadoc" value="false"/>
            <property name="minLineCount" value="-1"/>
            <property name="tokens" value="METHOD_DEF, CTOR_DEF, ANNOTATION_FIELD_DEF"/>
        </module>

        <!-- Every field (including private constants and instance variables)
             must have a Javadoc comment. -->
        <module name="JavadocVariable">
            <property name="scope" value="private"/>
        </module>

        <!-- Prohibit direct System.out / System.err access.
             Use Console.root() or implement ConsoleFeatures and call log() / warn().
             Legacy files are suppressed in checkstyle-suppressions.xml. -->
        <module name="RegexpSinglelineJava">
            <property name="id" value="DirectSystemOut"/>
            <property name="format" value="System\.(out|err)\."/>
            <property name="message" value="Use Console.root() or ConsoleFeatures instead of System.out/err. See base/io/README.md."/>
            <property name="ignoreComments" value="true"/>
        </module>

        <!-- Prohibit e.printStackTrace() which writes directly to stderr.
             Use Console.root().alert(message, exception) instead. -->
        <module name="RegexpSinglelineJava">
            <property name="id" value="DirectSystemOut"/>
            <property name="format" value="\bprintStackTrace\(\)"/>
            <property name="message" value="Use Console.root().alert(message, exception) instead of printStackTrace(). See base/io/README.md."/>
            <property name="ignoreComments" value="true"/>
        </module>

        <!-- Prohibit use of 'var' keyword - always use explicit types -->
        <module name="RegexpSinglelineJava">
            <property name="format" value="^\s*(var|final\s+var)\s+\w+\s*="/>
            <property name="message" value="Use of 'var' is prohibited. Use explicit type declarations."/>
            <property name="ignoreComments" value="true"/>
        </module>

        <!-- Prohibit @SuppressWarnings -->
        <module name="RegexpSinglelineJava">
            <property name="format" value="@SuppressWarnings"/>
            <property name="message" value="@SuppressWarnings is prohibited."/>
            <property name="ignoreComments" value="true"/>
        </module>

        <!-- Detect fully-qualified class references that should use imports.
             Matches common java.* packages used inline (not in import
             statements). Uses severity=warning until existing violations
             are cleaned up.
             Note: ErrorProne was considered but cannot be added because pom.xml
             modifications are not permitted, and ErrorProne lacks a built-in check
             for this pattern. Checkstyle RegexpSinglelineJava is a better fit. -->
        <module name="RegexpSinglelineJava">
            <property name="format" value="^(?!\s*import\b)(?!\s*package\b).*\bjava\.(util|io|nio|lang|math|net|time)\.[A-Z]\w+[^;]"/>
            <property name="message" value="Use an import instead of a fully-qualified class reference."/>
            <property name="ignoreComments" value="true"/>
            <property name="severity" value="warning"/>
        </module>
        <!-- Prohibit decorative prefixes in log/warn calls.

             The logging framework already prefixes every line with the
             timestamp, class name, method name, and (where relevant) the
             task identifier.  ANY agent-added prefix to the message text
             itself is therefore redundant noise: it shows up next to the
             framework's own decoration, clutters the output, and exists
             only because the agent wants something easy to grep for. The
             agent isn't the decorator of the log files.

             Forbidden shapes (and example uses each tries to slip in):

               [Tag] message              log("[Prototypes] Library refresh");
               (Tag) message              log("(SECRETS) wired up");
               <Tag> message              log("<DEBUG> mode active");
               TAG: message               log("DIAG: pushedToolsConfig=...");
               TAG - message              log("INFO - controller starting");
               4+ CAPS at start of msg    log("DEBUG something happened");
                                          log("FIXME this is broken");
                                          log("TODO wire up X");
               emoji/icon prefixes        log("🔧 reconfiguring ...");
                                          log("→ launching subprocess");

             Write the message directly: log("Library refresh complete");
             If a piece of information is structurally important enough to
             grep for, give the value a stable variable-style name in the
             text (e.g. "pushedToolsConfig=..."). The reader can grep on
             that name; you don't need a separate tag in front of it. -->
        <module name="RegexpSinglelineJava">
            <property name="id" value="BracketLabelInLog"/>
            <property name="format" value="\b(log|warn)\s*\(\s*&quot;\[[A-Za-z0-9]"/>
            <property name="message" value="Do not prefix log/warn messages with bracket labels such as '[Tag] message'. Write the message text directly without a label prefix."/>
            <property name="ignoreComments" value="true"/>
        </module>
        <module name="RegexpSinglelineJava">
            <property name="id" value="ParenLabelInLog"/>
            <property name="format" value="\b(log|warn)\s*\(\s*&quot;\([A-Za-z0-9]"/>
            <property name="message" value="Do not prefix log/warn messages with parenthesised labels such as '(Tag) message'. Write the message text directly without a label prefix."/>
            <property name="ignoreComments" value="true"/>
        </module>
        <module name="RegexpSinglelineJava">
            <property name="id" value="AngleLabelInLog"/>
            <property name="format" value="\b(log|warn)\s*\(\s*&quot;&lt;[A-Za-z0-9]"/>
            <property name="message" value="Do not prefix log/warn messages with angle-bracket labels such as '&lt;Tag&gt; message'. Write the message text directly without a label prefix."/>
            <property name="ignoreComments" value="true"/>
        </module>
        <module name="RegexpSinglelineJava">
            <property name="id" value="CapsLabelInLog"/>
            <!-- 4+ uppercase letters at the start of a log message catches
                 DIAG, INFO, WARN, DEBUG, TRACE, ERROR, FIXME, TODO, NOTE,
                 STEP, HACK, XXX -prefixed variations like DEBUG:, INFO -,
                 and any future "I'll just stick an all-caps marker on the
                 front so I can grep" instinct. The framework's own level
                 (already encoded by the log/warn method choice) and class
                 name are sufficient. -->
            <property name="format" value="\b(log|warn)\s*\(\s*&quot;[A-Z]{4,}"/>
            <property name="message" value="Do not prefix log/warn messages with all-caps labels (DIAG, INFO, DEBUG, FIXME, TODO, etc.). The logging framework already provides level and class context; write the message text directly."/>
            <property name="ignoreComments" value="true"/>
        </module>
        <module name="RegexpSinglelineJava">
            <property name="id" value="SymbolPrefixInLog"/>
            <!-- Catches non-ASCII prefix decoration like emoji, arrows, or
                 box-drawing characters. The first character of a log
                 message must be a normal ASCII alphanumeric or punctuation
                 that belongs to the actual sentence — not an icon. -->
            <property name="format" value="\b(log|warn)\s*\(\s*&quot;[^\x00-\x7F]"/>
            <property name="message" value="Do not prefix log/warn messages with non-ASCII decoration (emoji, arrows, box-drawing). Start the message with the actual content."/>
            <property name="ignoreComments" value="true"/>
        </module>
    </module>
</module>
