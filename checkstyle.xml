<?xml version="1.0"?>
<!DOCTYPE module PUBLIC
        "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
        "https://checkstyle.org/dtds/configuration_1_3.dtd">

<!--
    Project-wide code quality rules applied to every module in the default build.

    Rules applied:
      - FileLength           : Java source files are capped at 1600 lines.  Files
                               larger than this are a sign that a class is doing
                               too much and should be split into focused collaborators.
                               Eleven legacy files exceed this limit and are individually
                               exempted via SuppressionSingleFilter (see below).  Those
                               files are tracked by scripts/check-exempt-file-lengths.sh,
                               which enforces that they do not grow beyond their current
                               sizes.
      - JavadocPackage       : every package needs a package-info.java with Javadoc
      - MissingJavadocType   : every type declaration needs a Javadoc comment
      - MissingJavadocMethod : every method and constructor needs a Javadoc comment
      - JavadocVariable      : every field needs a Javadoc comment
      - RegexpSinglelineJava : prohibits use of 'var' and '@SuppressWarnings'
      - RegexpSinglelineJava : prohibits System.out/err and e.printStackTrace().
                               Use Console.root() or implement ConsoleFeatures instead.
                               191 legacy files are suppressed via checkstyle-suppressions.xml
                               and must be migrated over time.  New files may not be added
                               to the suppression list.
      - RegexpSinglelineJava : prohibits bracket-prefixed labels in log/warn calls,
                               e.g. log("[Tag] message").  Write messages directly.
                               Enforced at severity=error.  No suppressions permitted.
-->
<module name="Checker">
    <property name="charset" value="UTF-8"/>
    <property name="severity" value="error"/>
    <property name="fileExtensions" value="java"/>

    <!-- Exclude auto-generated source files -->
    <module name="BeforeExecutionExclusionFileFilter">
        <property name="fileNamePattern" value="[/\\]generated[/\\]"/>
    </module>

    <!-- Cap Java source files at 1600 lines.  Files larger than this are a
         sign that a class is doing too much and should be split into focused
         collaborators.  The limit was lowered from 1800 to 1600 to reduce
         the amount of context agents must read to understand a class.
         Eleven legacy files exceed this limit and are individually exempted
         via SuppressionSingleFilter (see below).  All are tracked by
         scripts/check-exempt-file-lengths.sh, which enforces that they do
         not grow beyond their sizes at the time of exemption. -->
    <module name="FileLength">
        <property name="max" value="1600"/>
    </module>

    <!-- Exempt legacy files that currently exceed 1600 lines.  These files are
         tracked by scripts/check-exempt-file-lengths.sh, which prevents them
         from growing beyond their sizes at the time of exemption.
         To remove an exemption: split the file below 1600 lines, then remove
         its SuppressionSingleFilter entry and its entry in check-exempt-file-lengths.sh. -->

    <!-- Pre-existing exemptions (exceeded 1800 lines): -->
    <module name="SuppressionSingleFilter">
        <property name="checks" value="FileLength"/>
        <property name="files" value="CollectionFeatures\.java"/>
    </module>
    <module name="SuppressionSingleFilter">
        <property name="checks" value="FileLength"/>
        <property name="files" value="Expression\.java"/>
    </module>
    <module name="SuppressionSingleFilter">
        <property name="checks" value="FileLength"/>
        <property name="files" value="AttentionFeatures\.java"/>
    </module>
    <!-- LayerFeatures.java grew past 1800 lines when Javadoc was added -->
    <module name="SuppressionSingleFilter">
        <property name="checks" value="FileLength"/>
        <property name="files" value="LayerFeatures\.java"/>
    </module>

    <!-- Console.java is the logging system itself — it must write to System.out/err
         directly to deliver output.  The DirectSystemOut rule is suppressed for it. -->
    <module name="SuppressionSingleFilter">
        <property name="id" value="DirectSystemOut"/>
        <property name="files" value="Console\.java"/>
    </module>

    <!-- Require package-info.java with a Javadoc comment for every package -->
    <module name="JavadocPackage"/>

    <module name="TreeWalker">

        <!-- Every type declaration (class, interface, enum, annotation, record)
             must have a Javadoc comment, including private and package-private types. -->
        <module name="MissingJavadocType">
            <property name="scope" value="private"/>
        </module>

        <!-- Every method and constructor must have a Javadoc comment,
             including private helpers.  Property-style getters and setters
             are NOT exempt: they must also document the field they access. -->
        <module name="MissingJavadocMethod">
            <property name="scope" value="private"/>
            <property name="allowMissingPropertyJavadoc" value="false"/>
            <property name="minLineCount" value="-1"/>
            <property name="tokens" value="METHOD_DEF, CTOR_DEF, ANNOTATION_FIELD_DEF"/>
        </module>

        <!-- Every field (including private constants and instance variables)
             must have a Javadoc comment. -->
        <module name="JavadocVariable">
            <property name="scope" value="private"/>
        </module>

        <!-- Prohibit direct System.out / System.err access.
             Use Console.root() or implement ConsoleFeatures and call log() / warn().
             Legacy files are suppressed in checkstyle-suppressions.xml. -->
        <module name="RegexpSinglelineJava">
            <property name="id" value="DirectSystemOut"/>
            <property name="format" value="System\.(out|err)\."/>
            <property name="message" value="Use Console.root() or ConsoleFeatures instead of System.out/err. See base/io/README.md."/>
            <property name="ignoreComments" value="true"/>
        </module>

        <!-- Prohibit e.printStackTrace() which writes directly to stderr.
             Use Console.root().alert(message, exception) instead. -->
        <module name="RegexpSinglelineJava">
            <property name="id" value="DirectSystemOut"/>
            <property name="format" value="\bprintStackTrace\(\)"/>
            <property name="message" value="Use Console.root().alert(message, exception) instead of printStackTrace(). See base/io/README.md."/>
            <property name="ignoreComments" value="true"/>
        </module>

        <!-- Prohibit use of 'var' keyword - always use explicit types -->
        <module name="RegexpSinglelineJava">
            <property name="format" value="^\s*(var|final\s+var)\s+\w+\s*="/>
            <property name="message" value="Use of 'var' is prohibited. Use explicit type declarations."/>
            <property name="ignoreComments" value="true"/>
        </module>

        <!-- Prohibit @SuppressWarnings -->
        <module name="RegexpSinglelineJava">
            <property name="format" value="@SuppressWarnings"/>
            <property name="message" value="@SuppressWarnings is prohibited."/>
            <property name="ignoreComments" value="true"/>
        </module>

        <!-- Detect fully-qualified class references that should use imports.
             Matches common java.* packages used inline (not in import
             statements). Uses severity=warning until existing violations
             are cleaned up.
             Note: ErrorProne was considered but cannot be added because pom.xml
             modifications are not permitted, and ErrorProne lacks a built-in check
             for this pattern. Checkstyle RegexpSinglelineJava is a better fit. -->
        <module name="RegexpSinglelineJava">
            <property name="format" value="^(?!\s*import\b)(?!\s*package\b).*\bjava\.(util|io|nio|lang|math|net|time)\.[A-Z]\w+[^;]"/>
            <property name="message" value="Use an import instead of a fully-qualified class reference."/>
            <property name="ignoreComments" value="true"/>
            <property name="severity" value="warning"/>
        </module>
        <!-- Prohibit bracket-prefixed labels in log/warn calls.
             Pattern log("[ClassName] message") or log("[Tag] message") embeds
             redundant source identification that the logging framework already
             provides via the class name, and clutters log output with noise.
             Write the message directly: log("message") instead.
             Examples of the prohibited pattern:
               log("[Prototypes] Library refresh complete");
               log("[LICM] " + scope.getName());
               log("[MoonbeamComponentTest] testSingleFmeEmbed: " + elapsed);
             New code must comply from day one. -->
        <module name="RegexpSinglelineJava">
            <property name="id" value="BracketLabelInLog"/>
            <property name="format" value="\b(log|warn)\s*\(\s*&quot;\[[A-Za-z0-9]"/>
            <property name="message" value="Do not prefix log/warn messages with bracket labels such as '[Tag] message'. Write the message text directly without a label prefix."/>
            <property name="ignoreComments" value="true"/>
        </module>
    </module>
</module>
